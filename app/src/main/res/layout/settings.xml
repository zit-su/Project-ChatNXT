<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear_header"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:background="#FFFFFF"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="horizontal">
		<ImageView
			android:id="@+id/back"
			android:layout_width="30dp"
			android:layout_height="30dp"
			android:padding="7dp"
			android:src="@drawable/ic_back"
			android:scaleType="centerCrop" />
		<LinearLayout
			android:id="@+id/linear_div"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginRight="20dp"
			android:padding="8dp"
			android:orientation="horizontal"
			android:layout_weight="1" />
		<LinearLayout
			android:id="@+id/linear_logout"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="3dp"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal"
			android:layout_gravity="bottom">
			<TextView
				android:id="@+id/logout_txt"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:paddingLeft="8dp"
				android:paddingTop="8dp"
				android:paddingRight="3dp"
				android:paddingBottom="8dp"
				android:text="Logout"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#F44336" />
			<ImageView
				android:id="@+id/imageview_logout"
				android:layout_width="25dp"
				android:layout_height="25dp"
				android:padding="1dp"
				android:src="@drawable/logout_ic"
				android:scaleType="centerInside"
				android:layout_gravity="center_horizontal|center_vertical" />
		</LinearLayout>
	</LinearLayout>
	<LinearLayout
		android:id="@+id/linear_bg"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="#FFFFFF"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/linear4"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="@android:color/transparent"
			android:gravity="center_horizontal"
			android:orientation="vertical">
			<de.hdodenhof.circleimageview.CircleImageView
				android:id="@+id/circleimageview1"
				android:layout_width="70dp"
				android:layout_height="70dp"
				android:layout_marginTop="15dp"
				android:src="@drawable/profile_image"
				app:civ_border_width="5dp"
				app:civ_border_color="#ffffff"
				app:civ_circle_background_color="#FFFFFF"
				app:civ_border_overlay="true" />
			<TextView
				android:id="@+id/username"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:paddingLeft="8dp"
				android:paddingTop="8dp"
				android:paddingRight="8dp"
				android:paddingBottom="2dp"
				android:text="SunnyMavale"
				android:textSize="18sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/email"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:paddingLeft="8dp"
				android:paddingRight="8dp"
				android:paddingBottom="8dp"
				android:text="sunnavale\@gg.com"
				android:textSize="11sp"
				android:textColor="#000000" />
			<LinearLayout
				android:id="@+id/edit_button"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="15dp"
				android:layout_marginBottom="8dp"
				android:padding="3dp"
				android:background="#1A3764"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/edit_profile_text"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:paddingLeft="5dp"
					android:paddingTop="5dp"
					android:paddingBottom="5dp"
					android:text="Edit Profile"
					android:textSize="14sp"
					android:textColor="#FFFFFF" />
				<ImageView
					android:id="@+id/go_to_profile"
					android:layout_width="20dp"
					android:layout_height="20dp"
					android:padding="3dp"
					android:src="@drawable/go_white"
					android:scaleType="centerCrop"
					android:layout_gravity="center_horizontal|center_vertical" />
			</LinearLayout>
		</LinearLayout>
		<ScrollView
			android:id="@+id/vscroll1"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:background="@android:color/transparent">
			<LinearLayout
				android:id="@+id/linear_vs_child"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<LinearLayout
					android:id="@+id/linear5"
					android:layout_width="match_parent"
					android:layout_height="2dp"
					android:layout_marginTop="5dp"
					android:layout_marginBottom="5dp"
					android:padding="8dp"
					android:background="#E0E0E0"
					android:orientation="horizontal" />
				<TextView
					android:id="@+id/textview6"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="8dp"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:text="Profile Switch"
					android:textSize="12sp"
					android:textColor="#9E9E9E" />
				<LinearLayout
					android:id="@+id/Account_switch_layout"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="20dp"
					android:layout_marginTop="2dp"
					android:layout_marginRight="20dp"
					android:layout_marginBottom="2dp"
					android:padding="5dp"
					android:background="#F0F2F5"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/profile_switch"
						android:layout_width="40dp"
						android:layout_height="40dp"
						android:padding="5dp"
						android:background="#FFFFFF"
						android:src="@drawable/profile_switch"
						android:scaleType="centerCrop"
						android:layout_gravity="center_horizontal|center_vertical" />
					<TextView
						android:id="@+id/textview5"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Switch Account "
						android:textSize="14sp"
						android:textStyle="bold"
						android:textColor="#000000"
						android:layout_weight="1" />
					<ImageView
						android:id="@+id/btn_switch"
						android:layout_width="40dp"
						android:layout_height="40dp"
						android:padding="5dp"
						android:src="@drawable/switch_btn"
						android:scaleType="centerCrop" />
				</LinearLayout>
				<TextView
					android:id="@+id/instraction1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="8dp"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:text="Security &amp; Privacy"
					android:textSize="12sp"
					android:textColor="#9E9E9E" />
				<LinearLayout
					android:id="@+id/linear_q_chat"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="20dp"
					android:layout_marginTop="5dp"
					android:layout_marginRight="20dp"
					android:layout_marginBottom="5dp"
					android:padding="5dp"
					android:background="#F0F2F5"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<TextView
						android:id="@+id/qchat"
						android:layout_width="40dp"
						android:layout_height="40dp"
						android:padding="5dp"
						android:gravity="center_horizontal|center_vertical"
						android:text="Q"
						android:textSize="20sp"
						android:textStyle="bold"
						android:textColor="#000000" />
					<Switch
						android:id="@+id/q_chat"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:background="@android:color/transparent"
						android:gravity="left|center_vertical"
						android:text="Show PairKey (QuickChat)"
						android:textSize="14sp"
						android:textStyle="bold"
						android:textColor="#0C0F18" />
				</LinearLayout>
				<TextView
					android:id="@+id/textview7"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="8dp"
					android:layout_marginTop="5dp"
					android:padding="8dp"
					android:text="Customize Options"
					android:textSize="12sp"
					android:textColor="#9E9E9E" />
				<LinearLayout
					android:id="@+id/linear_notification"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="20dp"
					android:layout_marginTop="5dp"
					android:layout_marginRight="20dp"
					android:layout_marginBottom="5dp"
					android:padding="5dp"
					android:background="#F0F2F5"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/notify_img"
						android:layout_width="40dp"
						android:layout_height="40dp"
						android:padding="8dp"
						android:background="#FFFFFF"
						android:src="@drawable/notification_on"
						android:scaleType="centerCrop"
						android:layout_gravity="center_horizontal|center_vertical" />
					<Switch
						android:id="@+id/notifications"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:background="@android:color/transparent"
						android:gravity="left|center_vertical"
						android:text="Push Notifications"
						android:textSize="14sp"
						android:textStyle="bold"
						android:textColor="#0C0F18" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/linear_font"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="20dp"
					android:layout_marginTop="5dp"
					android:layout_marginRight="20dp"
					android:layout_marginBottom="5dp"
					android:padding="5dp"
					android:background="#F0F2F5"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/font_img"
						android:layout_width="40dp"
						android:layout_height="40dp"
						android:padding="5dp"
						android:background="#FFFFFF"
						android:src="@drawable/font_icon"
						android:scaleType="centerCrop"
						android:layout_gravity="center_horizontal|center_vertical" />
					<LinearLayout
						android:id="@+id/linear6"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_horizontal|center_vertical"
						android:orientation="vertical">
						<Switch
							android:id="@+id/font"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:background="@android:color/transparent"
							android:gravity="left|center_vertical"
							android:text="Custom Fonts"
							android:textSize="14sp"
							android:textStyle="bold"
							android:textColor="#0C0F18" />
						<TextView
							android:id="@+id/textview8"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:background="@android:color/transparent"
							android:text="Select Font From Local"
							android:textSize="16sp"
							android:textColor="#7C7796" />
					</LinearLayout>
				</LinearLayout>
			</LinearLayout>
		</ScrollView>
	</LinearLayout>
</LinearLayout>
